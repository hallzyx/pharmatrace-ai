# PharmaTrace AI — all variables are OPTIONAL. Copy to a real .env to use.
# With none set, the agent runs in deterministic mock mode (demo-safe).

# --- Foundry IQ: Azure OpenAI / GPT-4o (real multi-step reasoning narration) ---
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Work IQ: Teams Incoming Webhook (live critical alerts) ---
TEAMS_WEBHOOK_URL=

# --- Hedera Consensus Service (public tamper-proof ledger anchoring) ---
# Get a free testnet account at https://portal.hedera.com
HEDERA_ACCOUNT_ID=0.0.xxxx
HEDERA_PRIVATE_KEY=
HEDERA_NETWORK=testnet
# Optional: pin a topic to reuse (created on first run if left blank).
# Run `python check_hedera.py` once to create one and print its id.
HEDERA_TOPIC_ID=
